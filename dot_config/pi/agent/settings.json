      "timeoutMs": 3600000
    }
  },
  "httpIdleTimeoutMs": 0,
  "defaultThinkingLevel": "medium",
  "packages": [
    "npm:pi-mermaid",
    {
      "source": "git:git@github.com/mcollina/pi-ollama-web-search",
      "extensions": [
        "-extensions/ollama-web-search.ts"
      ]
    }
  ],
  "collapseChangelog": true,
  "quietStartup": true
}