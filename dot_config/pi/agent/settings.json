{
  "lastChangelogVersion": "0.80.6",
  "defaultProvider": "llama.cpp",
  "defaultModel": "Qwen3.6-27B",
  "hideThinkingBlock": false,
  "autocompleteMaxVisible": 10,
  "theme": "gruvbox-dark-hard",
  "verbose": true,
  "debug": {
